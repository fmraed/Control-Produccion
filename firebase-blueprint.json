{
  "entities": {
    "ProductionReport": {
      "title": "Production Report",
      "description": "A daily production report (parte de producción)",
      "type": "object",
      "properties": {
        "supervisor": { "type": "string" },
        "fecha": { "type": "string", "format": "date" },
        "planilla": { "type": "string" },
        "lote": { "type": "string" },
        "linea": { "type": "string" },
        "velocidad": { "type": "number" },
        "sabor": { "type": "string" },
        "tamano": { "type": "number" },
        "entraTurno": { "type": "string" },
        "saleTurno": { "type": "string" },
        "tiempoBruto": { "type": "number" },
        "jarabeInicial": { "type": "number" },
        "jarabeFinal": { "type": "number" },
        "contInicial": { "type": "number" },
        "contFinal": { "type": "number" },
        "botRotas": { "type": "number" },
        "botellas": { "type": "number" },
        "paquetes": { "type": "number" },
        "co2": { "type": "number" },
        "observaciones": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "hourlyProduction": { "type": "array" },
        "downtimes": { "type": "array" }
      },
      "required": ["supervisor", "fecha", "planilla", "linea", "authorId", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "produccion", "calidad", "jefe_produccion"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt", "updatedAt"]
    },
    "AllowedUser": {
      "title": "Allowed User",
      "description": "Pre-registered users allowed to sign up",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "produccion", "calidad", "jefe_produccion"] },
        "sector": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "ElaboracionReport": {
      "title": "Elaboracion Report",
      "description": "A daily elaboration report",
      "type": "object",
      "properties": {
        "fecha": { "type": "string", "format": "date" },
        "turno": { "type": "string" },
        "planilla": { "type": "string" },
        "quimico": { "type": "string" },
        "lote": { "type": "string" },
        "linea": { "type": "string" },
        "marca": { "type": "string" },
        "sabor": { "type": "string" },
        "tamano": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "hourlyData": { "type": "array" }
      },
      "required": ["fecha", "turno", "planilla", "quimico", "lote", "linea", "marca", "sabor", "tamano", "createdAt", "authorId", "hourlyData"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Personnel information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "legajo": { "type": "string" },
        "position": { "type": "string" },
        "active": { "type": "boolean" },
        "hireDate": { "type": "string" },
        "terminationDate": { "type": "string" },
        "vacationAdjustment": { "type": "number" },
        "compensationAdjustment": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "legajo", "active", "createdAt"]
    },
    "MonthlyGoal": {
      "title": "Monthly Goal",
      "description": "Monthly production target for a specific product",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "marca": { "type": "string" },
        "sabor": { "type": "string" },
        "tamano": { "type": "number" },
        "quantity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["month", "marca", "sabor", "tamano", "quantity", "createdAt", "updatedAt"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "Daily attendance and overtime",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "employeeLegajo": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "shift": { "type": "string" },
        "line": { "type": "string" },
        "status": { "type": "string", "enum": ["Presente", "Ausente", "Tarde", "Licencia", "Vacaciones", "Feriado"] },
        "overtimeHours": { "type": "number" },
        "observations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["employeeId", "date", "shift", "status", "createdAt", "authorId"]
    },
    "ShiftAssignment": {
      "title": "Shift Assignment",
      "description": "Weekly planning assignment",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "shift": { "type": "string" },
        "line": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["employeeId", "date", "shift", "line", "createdAt", "authorId"]
    },
    "MonthlySnapshot": {
      "title": "Monthly Snapshot",
      "description": "Persisted results of a month's management summary",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "year": { "type": "number" },
        "stats": { "type": "object" },
        "configAtTime": { "type": "object" },
        "isClosed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["month", "year", "stats", "isClosed", "createdAt"]
    },
    "ProductionPlan": {
      "title": "Production Plan",
      "description": "Planned production for a specific shift and line",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "shift": { "type": "string", "enum": ["Mañana", "Tarde", "Noche"] },
        "linea": { "type": "string" },
        "marca": { "type": "string" },
        "sabor": { "type": "string" },
        "tamano": { "type": "number" },
        "plannedPacks": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Published"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["date", "shift", "linea", "marca", "sabor", "tamano", "plannedPacks", "status", "createdAt", "authorId"]
    },
    "ScheduleAuditLog": {
      "title": "Schedule Audit Log",
      "description": "Log of actions performed on production plans",
      "type": "object",
      "properties": {
        "planId": { "type": "string" },
        "action": { "type": "string", "enum": ["update", "publish", "delete"] },
        "datePlan": { "type": "string", "format": "date" },
        "timestamp": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "changes": { "type": "array" }
      },
      "required": ["planId", "action", "datePlan", "timestamp", "authorId"]
    },
    "DailyStock": {
      "title": "Daily Stock",
      "description": "Stock snapshot for a specific day",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "stocks": { "type": "object", "description": "Map of product key to stock quantity" },
        "savedAt": { "type": "string", "format": "date-time" },
        "savedBy": { "type": "string" }
      },
      "required": ["date", "stocks", "savedAt", "savedBy"]
    },
    "MonthlyRealEnergy": {
      "title": "Monthly Real Energy",
      "description": "Real energy consumption record for a specific month",
      "type": "object",
      "properties": {
        "kwh": { "type": "number" },
        "amount": { "type": "number" }
      },
      "required": ["kwh"]
    },
    "PhysicalInventory": {
      "title": "Physical Inventory",
      "description": "An uploaded physical inventory containing parsed items from an Excel file",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array" }
      },
      "required": ["id", "fileName", "uploadedAt", "items"]
    },
    "InsumosTransit": {
      "title": "Insumos Transit",
      "description": "Materials and supplies currently in transit",
      "type": "object",
      "properties": {
        "requisitionNumber": { "type": "string" },
        "needDate": { "type": "string" },
        "issueDate": { "type": "string" },
        "code": { "type": "string" },
        "description": { "type": "string" },
        "specification": { "type": "string" },
        "unit": { "type": "string" },
        "status": { "type": "string" },
        "requestedQuantity": { "type": "number" },
        "arrivedQuantity": { "type": "number" }
      },
      "required": ["requisitionNumber", "code", "description", "requestedQuantity", "arrivedQuantity"]
    }
  },
  "firestore": {
    "physical_inventories/{inventoryId}": {
      "schema": { "$ref": "#/entities/PhysicalInventory" },
      "description": "Stores history of loaded Excel physical inventories."
    },
    "daily_stocks/{dateId}": {
      "schema": { "$ref": "#/entities/DailyStock" },
      "description": "Stores daily stock snapshots."
    },
    "schedule_audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/ScheduleAuditLog" },
      "description": "Stores logs of changes to production plans."
    },
    "production_reports/{reportId}": {
      "schema": { "$ref": "#/entities/ProductionReport" },
      "description": "Stores all production reports."
    },
    "production_plans/{planId}": {
      "schema": { "$ref": "#/entities/ProductionPlan" },
      "description": "Stores future production plans."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "elaboracion_reports/{reportId}": {
      "schema": { "$ref": "#/entities/ElaboracionReport" },
      "description": "Stores all elaboration reports."
    },
    "employees/{employeeId}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Stores personnel list."
    },
    "attendance_records/{recordId}": {
      "schema": { "$ref": "#/entities/AttendanceRecord" },
      "description": "Stores daily attendance and overtime."
    },
    "shift_assignments/{assignmentId}": {
      "schema": { "$ref": "#/entities/ShiftAssignment" },
      "description": "Stores weekly planning assignments."
    },
    "monthly_snapshots/{snapshotId}": {
      "schema": { "$ref": "#/entities/MonthlySnapshot" },
      "description": "Stores persisted monthly management summaries."
    },
    "allowed_users/{email}": {
      "schema": { "$ref": "#/entities/AllowedUser" },
      "description": "Stores pre-registered users whitelist."
    },
    "monthly_goals/{goalId}": {
      "schema": { "$ref": "#/entities/MonthlyGoal" },
      "description": "Stores monthly production targets."
    },
    "energyRecords/{docId}": {
      "schema": { "$ref": "#/entities/MonthlyRealEnergy" },
      "description": "Stores monthly real energy consumption records."
    },
    "insumos_transits/{transitId}": {
      "schema": { "$ref": "#/entities/InsumosTransit" },
      "description": "Stores materials and supplies currently in transit."
    }
  }
}
