rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // Collection: users
    // Document ID: user.uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - role: string (required, 'admin' | 'user')
    //   - photoURL: string (optional)
    //   - createdAt: string (required)
    //   - updatedAt: string (required)
    //
    // Collection: elaboracion_reports
    // Document ID: auto-generated
    // Fields:
    //   - fecha: string (required)
    //   - turno: string (required)
    //   - planilla: string (required)
    //   - quimico: string (required)
    //   - lote: string (required)
    //   - linea: string (required)
    //   - marca: string (required)
    //   - sabor: string (required)
    //   - tamano: number (required)
    //   - createdAt: string (required)
    //   - authorId: string (required)
    //   - hourlyData: array (required)
    //
    // ===============================================================
    //
    // Collection: production_reports
    // Document ID: auto-generated
    // Fields:
    //   - supervisor: string (required)
    //   - fecha: string (required)
    //   - planilla: string (required)
    //   - lote: string (optional)
    //   - linea: string (required)
    //   - velocidad: number (optional)
    //   - sabor: string (optional)
    //   - tamano: number (optional)
    //   - entraTurno: string (optional)
    //   - saleTurno: string (optional)
    //   - tiempoBruto: number (optional)
    //   - jarabeInicial: number (optional)
    //   - jarabeFinal: number (optional)
    //   - contInicial: number (optional)
    //   - contFinal: number (optional)
    //   - botRotas: number (optional)
    //   - botellas: number (optional)
    //   - paquetes: number (optional)
    //   - co2: number (optional)
    //   - observaciones: string (optional)
    //   - createdAt: string (required, immutable)
    //   - authorId: string (required, immutable)
    //   - authorName: string (optional)
    //   - hourlyProduction: array (optional)
    //   - downtimes: array (optional)
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }
    
    function uidUnchanged() {
      return isAdmin() || !('authorId' in request.resource.data) ||
        request.resource.data.authorId == request.auth.uid;
    }
    
    function uidNotModified() {
      return isAdmin() || !('authorId' in request.resource.data) ||
        request.resource.data.authorId == resource.data.authorId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function isValidOptionalNumber(field) {
      return !(field in request.resource.data) || request.resource.data[field] is number;
    }
    
    function isValidOptionalArray(field) {
      return !(field in request.resource.data) || request.resource.data[field] is list;
    }

    function isValidOptionalMap(field) {
      return !(field in request.resource.data) || request.resource.data[field] is map;
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email.lower() == "fraed.fordrinks@gmail.com".lower());
    }

    // Domain Validators
    function isValidProductionReport(data) {
      return data.supervisor is string && data.fecha is string && data.planilla is string && data.linea is string;
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'displayName', 'role', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.role in ['admin', 'produccion', 'calidad', 'jefe_produccion'] &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidAllowedUser(data) {
      return hasRequiredFields(['email', 'role', 'createdAt']) &&
             data.email is string &&
             data.role in ['admin', 'produccion', 'calidad', 'jefe_produccion'] &&
             data.createdAt is string;
    }

    function isValidElaboracionReport(data) {
      return hasRequiredFields(['fecha', 'turno', 'planilla', 'quimico', 'lote', 'linea', 'marca', 'sabor', 'tamano', 'createdAt', 'authorId', 'hourlyData']) &&
             data.fecha is string &&
             data.turno is string &&
             data.planilla is string &&
             data.quimico is string &&
             data.lote is string &&
             data.linea is string &&
             data.marca is string &&
             data.sabor is string &&
             data.tamano is number &&
             data.createdAt is string &&
             data.authorId is string &&
             data.hourlyData is list;
    }

    function isValidEmployee(data) {
      return hasRequiredFields(['name', 'legajo', 'active', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.legajo is string && data.legajo.size() > 0 &&
             data.active is bool &&
             data.createdAt is string &&
             isValidOptionalString('position', 0, 100) &&
             isValidOptionalString('type', 0, 50) &&
             isValidOptionalString('sector', 0, 50) &&
             isValidOptionalString('rango', 0, 100) &&
             isValidOptionalString('convenio', 0, 100) &&
             isValidOptionalString('hireDate', 0, 50) &&
             isValidOptionalString('terminationDate', 0, 50) &&
             isValidOptionalNumber('vacationAdjustment') &&
             isValidOptionalNumber('compensationAdjustment');
    }

    function isValidMonthlyGoal(data) {
      return hasRequiredFields(['month', 'marca', 'sabor', 'tamano', 'quantity', 'createdAt', 'updatedAt']) &&
             data.month is string &&
             data.marca is string &&
             data.sabor is string &&
             data.tamano is number &&
             data.quantity is number &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidAttendanceRecord(data) {
      return hasRequiredFields(['employeeId', 'date', 'shift', 'status', 'createdAt', 'authorId']) &&
             data.employeeId is string &&
             data.date is string &&
             data.shift is string &&
             data.status in ["Presente", "Ausente", "Tarde", "Licencia", "Vacaciones", "Feriado", "Compensado"] &&
             data.createdAt is string &&
             data.authorId is string &&
             isValidOptionalString('employeeName', 0, 100) &&
             isValidOptionalString('employeeLegajo', 0, 50) &&
             isValidOptionalString('line', 0, 50) &&
             isValidOptionalNumber('overtimeHours') &&
             isValidOptionalString('observations', 0, 1000);
    }

    function isValidShiftAssignment(data) {
      return hasRequiredFields(['employeeId', 'date', 'shift', 'line', 'createdAt', 'authorId']) &&
             data.employeeId is string &&
             data.date is string &&
             data.shift is string &&
             data.line is string &&
             data.createdAt is string &&
             data.authorId is string;
    }

    function isValidMonthlySnapshot(data) {
      return hasRequiredFields(['month', 'year', 'stats', 'isClosed', 'createdAt']) &&
             data.month is string &&
             data.year is number &&
             data.stats is map &&
             data.isClosed is bool &&
             data.createdAt is string &&
             isValidOptionalMap('configAtTime');
    }

    function isValidPhysicalInventory(data) {
      return hasRequiredFields(['id', 'fileName', 'uploadedAt', 'items']) &&
             data.id is string &&
             data.fileName is string &&
             data.uploadedAt is string &&
             data.items is list;
    }

    function isValidProductionPlan(data) {
      return hasRequiredFields(['date', 'shift', 'linea', 'marca', 'sabor', 'tamano', 'plannedPacks', 'status', 'createdAt', 'authorId']) &&
             data.date is string &&
             data.shift in ['Mañana', 'Tarde', 'Noche'] &&
             data.linea is string &&
             data.marca is string &&
             data.sabor is string &&
             data.tamano is number &&
             data.plannedPacks is number &&
             data.status in ['Draft', 'Published'] &&
             data.createdAt is string &&
             data.authorId is string;
    }

    function isValidInsumosTransit(data) {
      return hasRequiredFields(['requisitionNumber', 'code', 'description', 'requestedQuantity', 'arrivedQuantity']) &&
             data.requisitionNumber is string &&
             data.code is string &&
             data.description is string &&
             data.requestedQuantity is number &&
             data.arrivedQuantity is number &&
             isValidOptionalString('status', 0, 100) &&
             isValidOptionalString('needDate', 0, 50) &&
             isValidOptionalString('issueDate', 0, 50) &&
             isValidOptionalString('specification', 0, 200) &&
             isValidOptionalString('unit', 0, 50);
    }

    function isValidScheduleAuditLog(data) {
      return hasRequiredFields(['planId', 'action', 'datePlan', 'timestamp', 'authorId']) &&
             data.planId is string &&
             data.action in ['update', 'publish', 'delete'] &&
             data.datePlan is string &&
             data.timestamp is string &&
             data.authorId is string &&
             isValidOptionalArray('changes');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /allowed_users/{email} {
      allow read, delete: if isAuthenticated() && (request.auth.token.email.lower() == email.lower() || isAdmin());
      allow create, update: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidEmployee(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAttendanceRecord(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidAttendanceRecord(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /shift_assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidShiftAssignment(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidShiftAssignment(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /monthly_snapshots/{snapshotId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /physical_inventories/{inventoryId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidPhysicalInventory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /monthly_goals/{goalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /elaboracion_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidElaboracionReport(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidElaboracionReport(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /config/{configId} {
      // All authenticated users need to read config for NewReportForm filtering
      allow read: if isAuthenticated();
      // Only admin can modify config
      allow write: if isAdmin();
    }

    match /live_production/{docId} {
      // Any authenticated user can read and write live production data
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /production_plans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProductionPlan(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidProductionPlan(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /production_plans_v2/{planId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    match /schedule_audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidScheduleAuditLog(request.resource.data) && uidUnchanged();
      allow update: if false; // Append-only audit log
      allow delete: if isAdmin();
    }

    match /monthly_stock_init/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /energyRecords/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /daily_stocks/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /insumos_transits/{transitId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidInsumosTransit(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /production_reports/{reportId} {
      // Allow any authenticated user to read reports for now, as it's a company dashboard
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && isValidProductionReport(request.resource.data) && (request.resource.data.authorId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidProductionReport(request.resource.data) && areImmutableFieldsUnchanged(['createdAt', 'authorId']);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}
